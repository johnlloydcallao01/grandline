# ========================================
# WEB APP SPECIFIC ENVIRONMENT VARIABLES
# ========================================
NEXT_PUBLIC_API_URL=https://grandline-cms.vercel.app/api

# Debug Configuration
NEXT_PUBLIC_DEBUG_FORMS=false

# API Authentication (Client-side accessible)
NEXT_PUBLIC_PAYLOAD_API_KEY=your_api_key_here

# Web Push (public key is safe for the browser)
NEXT_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY=your_public_vapid_key_here
