{
  "name": "@encreasl/cms",
  "version": "0.1.0",
  "description": "Encreasl CMS powered by PayloadCMS 3.0",
  "license": "MIT",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "build": "pnpm run generate:types && cross-env NODE_ENV=production NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" PAYLOAD_DROP_DATABASE=false next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev -p 3001",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint . --max-warnings 0",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_ENV=production PAYLOAD_MIGRATION_FORCE_ACCEPT_WARNING=true node --no-deprecation --max-old-space-size=384 ./scripts/start-production.mjs",
    "seed:branches": "npx tsx src/seeders/accounting-branches.ts",
    "seed:departments": "npx tsx src/seeders/accounting-departments.ts",
    "seed:locations": "npx tsx src/seeders/accounting-locations.ts",
    "seed:credit-notes": "pnpm exec tsx src/seeders/accounting-credit-notes.ts",
    "seed:ap-aging": "pnpm exec tsx src/seeders/accounting-ap-aging.ts",
    "seed:approval-workflows": "pnpm exec tsx src/seeders/accounting-approval-workflows.ts",
    "seed:expense-approval-requests": "pnpm exec tsx src/seeders/accounting-expense-approval-requests.ts",
    "seed:fixed-assets": "pnpm exec tsx src/seeders/accounting-fixed-assets.ts",
    "seed:lock-close-state": "pnpm exec tsx src/seeders/accounting-lock-close-state.ts",
    "seed:vendor-credits": "pnpm exec tsx src/seeders/accounting-vendor-credits.ts",
    "seed:payments-received": "pnpm exec tsx src/seeders/accounting-payments-received.ts",
    "seed:payments-made": "pnpm exec tsx src/seeders/accounting-payments-made.ts",
    "seed:deposits": "pnpm exec tsx src/seeders/accounting-deposits.ts",
    "seed:transfers": "pnpm exec tsx src/seeders/accounting-transfers.ts",
    "seed:bounced-payments": "pnpm exec tsx src/seeders/accounting-bounced-payments.ts",
    "seed:bank-transactions": "pnpm exec tsx src/seeders/accounting-bank-transactions.ts",
    "seed:bank-feeds": "pnpm exec tsx src/seeders/accounting-bank-feeds.ts",
    "seed:statement-imports": "pnpm exec tsx src/seeders/accounting-bank-statement-imports.ts",
    "seed:official-receipts": "pnpm exec tsx src/seeders/accounting-official-receipts.ts",
    "seed:overdue-invoices": "pnpm exec tsx src/seeders/accounting-overdue-invoices.ts",
    "seed:bank-reconciliations": "pnpm exec tsx src/seeders/accounting-bank-reconciliations.ts",
    "seed:journal-entries": "npx tsx src/seeders/accounting-journal-entries.ts",
    "seed:journal-entry-lines": "npx tsx src/seeders/accounting-journal-entry-lines.ts",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --no-experimental-strip-types\" pnpm exec playwright test",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts",
    "db:test": "node test-db-connection.js"
  },
  "dependencies": {
    "@grandline/chat-engine": "workspace:*",
    "@encreasl/redux": "workspace:*",
    "@floating-ui/react": "^0.27.19",
    "@payloadcms/db-postgres": "^3.80.0",
    "@payloadcms/next": "^3.80.0",
    "@payloadcms/payload-cloud": "^3.80.0",
    "@payloadcms/plugin-cloud-storage": "^3.80.0",
    "@payloadcms/richtext-lexical": "^3.80.0",
    "@payloadcms/ui": "^3.80.0",
    "@react-pdf/renderer": "^4.3.2",
    "cloudinary": "^2.7.0",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "graphql": "^16.8.1",
    "next": "^16.2.0",
    "payload": "^3.80.0",
    "pg": "^8.16.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "sharp": "0.34.2",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.31.0",
    "@playwright/test": "1.50.0",
    "@testing-library/react": "16.3.0",
    "@types/node": "^22.5.4",
    "@types/react": "19.1.0",
    "@types/react-dom": "19.1.2",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "@vitejs/plugin-react": "4.5.2",
    "baseline-browser-mapping": "^2.9.19",
    "eslint": "^9.16.0",
    "eslint-config-next": "^16.2.0",
    "jsdom": "26.1.0",
    "playwright": "1.50.0",
    "playwright-core": "1.50.0",
    "prettier": "^3.4.2",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "3.2.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": "^9 || ^10"
  }
}
